{
  "name": "bizim-discord-desktop",
  "version": "1.0.0",
  "description": "Suicide Hotline masaustu uygulamasi (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.bizimdiscord.app",
    "productName": "Suicide Hotline",
    "files": ["main.js", "preload.js", "icon.png"],
    "win": { "target": "nsis", "icon": "icon.png" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  }
}
